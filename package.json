{
  "name": "sweet-shop-pos",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "main": "electron-main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "desktop:dev": "electron .",
    "desktop:build": "electron-builder --win nsis",
    "service:install": "node scripts/install-service.js",
    "service:uninstall": "node scripts/uninstall-service.js",
    "backup:run": "node scripts/run-backup.js",
    "package:release": "powershell -ExecutionPolicy Bypass -File .\\scripts\\create-release.ps1"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "node-windows": "^1.0.0-beta.8",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.rameshsweets.pos",
    "productName": "Ramesh sweets",
    "directories": {
      "output": "dist"
    },
    "files": [
      "*.html",
      "*.js",
      "*.css",
      "package.json",
      ".env",
      ".env.example",
      "node_modules/**/*",
      "scripts/**/*"
    ],
    "extraFiles": [
      {
        "from": "backups",
        "to": "backups",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
